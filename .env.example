# ─── Required API keys ───────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
MISTRAL_API_KEY=your_mistral_api_key

# ─── Models (optional; sensible defaults shown) ──────────────────────────────
# Defaults are provider "latest" aliases — they auto-track the newest model, so you
# never edit version strings and deprecated versions never break the app.
# Set any of these to "auto" to instead discover the newest model from the provider
# API at runtime (queries the models-list endpoint once; pure, no alias reliance).
GEMINI_MODEL=gemini-flash-latest           # generator (mine + compose)
GEMINI_COMPOSER_MODEL=gemini-flash-latest  # (defaults to GEMINI_MODEL)
MISTRAL_MODEL=mistral-large-latest         # comparative judge (best general chat)

# ─── Pipeline tunables (optional) ────────────────────────────────────────────
# NBT_N_CANDIDATES=5     # best-of-N ideas per round (produced in ONE Gemini call)
# NBT_MAX_ROUNDS=2       # generate+judge rounds before returning the best
# NBT_MIN_COHERENCE=0.5  # quality bar
# NBT_MIN_NOVELTY=0.55   # quality bar
# NBT_TEMP_MIN=0.6       # composer temp at wildness 0
# NBT_TEMP_MAX=1.3       # composer temp at wildness 100
# LOG_LEVEL=INFO
