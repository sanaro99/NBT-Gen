# ─── Required API keys ───────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
MISTRAL_API_KEY=your_mistral_api_key

# ─── Models (optional; sensible defaults shown) ──────────────────────────────
GEMINI_MODEL=models/gemini-2.5-flash           # miner + polish
GEMINI_COMPOSER_MODEL=models/gemini-2.5-flash  # composer
MISTRAL_MODEL=mistral-small-latest             # comparative judge

# ─── Pipeline tunables (optional) ────────────────────────────────────────────
# NBT_N_ASSUMPTIONS=12   # assumptions mined per topic
# NBT_N_CANDIDATES=3     # best-of-N ideas composed per round (free tier: keep ≤3)
# NBT_MAX_ROUNDS=2       # compose+judge rounds before returning the best
# NBT_MIN_COHERENCE=0.5  # quality bar
# NBT_MIN_NOVELTY=0.55   # quality bar
# NBT_TEMP_MIN=0.6       # composer temp at wildness 0
# NBT_TEMP_MAX=1.3       # composer temp at wildness 100
# LOG_LEVEL=INFO
